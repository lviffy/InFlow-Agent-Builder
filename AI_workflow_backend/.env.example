# ------------------------------------------------------------
# AI Providers  (at least one of Groq OR Gemini is required)
# ------------------------------------------------------------

# Groq — primary LLM (llama-3.3-70b-versatile)
# Multiple keys auto-rotate on rate limits (429 errors)
GROQ_API_KEY1=gsk_...
GROQ_API_KEY2=gsk_...
GROQ_API_KEY3=gsk_...

# Google Gemini — fallback LLM (gemini-2.0-flash)
GEMINI_API_KEY=AIza...

# ------------------------------------------------------------
# Service Config
# ------------------------------------------------------------
PORT=8001
