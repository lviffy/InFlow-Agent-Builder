# Arbitrum Sepolia Configuration
PORT=3000

# Agent Backend URL (Python FastAPI service for tool execution)
AGENT_BACKEND_URL=http://localhost:8000

# Stylus Contract Addresses on Arbitrum Sepolia
# Deploy your Stylus contracts and add the addresses here
TOKEN_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
NFT_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: OpenAI API Key for future AI features
OPENAI_API_KEY=

# Groq API Key (Primary for AI features)
# Multiple keys for automatic fallback on rate limits (429 errors)
GROQ_API_KEY1=
GROQ_API_KEY2=
GROQ_API_KEY3=

# Google Gemini API Key for AI-powered token price fetching (Fallback)
GEMINI_API_KEY=

# Etherscan API Key for contract ABI fetching (Natural Language Executor)
ETHERSCAN_API_KEY=

# Optional: Pinata for IPFS (if you want to add IPFS support later)
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Supabase Configuration (for conversation memory)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Admin secret for cleanup endpoints (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SECRET=your_random_32_char_admin_secret_here

# Gmail Configuration (for email tool via nodemailer)
# Generate an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
